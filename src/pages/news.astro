---

<BaseLayout title="News · Haorui Li" description="News coverage and media mentions about Haorui Li">
  <header class="page-hero">
    <p class="page-hero__label">Coverage</p>
    <h1 class="page-hero__title">News</h1>
    <p class="page-hero__meta">{newsItems.length} mentions</p>
  </header>

  <table class="writing-index">
    <thead>
      <tr>
        <th scope="col">Date</th>
        <th scope="col">Coverage</th>
      </tr>
    </thead>
    <tbody>
      {
        newsItems.map((item) => (
          <tr>
            <td>
              {new Date(item.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
              })}
            </td>
            <td>
              <a class="title-link" href={item.url} target="_blank" rel="noreferrer">
                {item.title}
              </a>
              <span class="excerpt">{item.source} — {item.description}</span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</BaseLayout>
