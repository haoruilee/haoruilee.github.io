---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Writing archive · Haorui Li" description="All posts">
  <header class="page-hero">
    <p class="page-hero__label">Archive</p>
    <h1 class="page-hero__title">All writing</h1>
    <p class="page-hero__meta">{posts.length} pieces</p>
  </header>

  <table class="writing-index">
    <thead>
      <tr>
        <th scope="col">Date</th>
        <th scope="col">Title</th>
      </tr>
    </thead>
    <tbody>
      {
        posts.map((post) => (
          <tr>
            <td>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </td>
            <td>
              <a class="title-link" href={`/blog/${post.slug}`}>
                {post.data.title}
              </a>
              {post.data.description && (
                <span class="excerpt">{post.data.description}</span>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</BaseLayout>
