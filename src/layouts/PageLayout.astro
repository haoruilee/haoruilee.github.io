---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  label?: string;
}

const { title, description, pubDate, label = 'Page' } = Astro.props;
const dateStr = pubDate
  ? pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="page-hero">
      <p class="page-hero__label">{label}</p>
      <h1 class="page-hero__title">{title}</h1>
      {dateStr && <p class="page-hero__meta">{dateStr}</p>}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
